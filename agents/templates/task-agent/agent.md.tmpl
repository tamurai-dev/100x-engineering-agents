---
# ============================================================
# Subagent 定義テンプレート
# Claude Code v2.1+ frontmatter 仕様準拠（全16フィールド）
# https://docs.anthropic.com/en/docs/claude-code/sub-agents
#
# 使い方:
#   cp agents/templates/task-agent/agent.md.tmpl agents/agents/<name>.md
#   各フィールドを編集し、不要なオプションフィールドは削除する
# ============================================================

# --- 必須フィールド ---
name: <agent-name>                    # 小文字+ハイフンのみ、最大64文字
description: >                        # 最低10文字。いつ起動するかを第三者視点で記述
  このエージェントの役割と、どのような状況で起動されるべきかを記述する。
  "PROACTIVELY" を含めると Claude が自動的に委任する頻度が上がる。

# --- モデル設定 ---
model: sonnet                         # sonnet | opus | haiku | inherit | フルモデルID (例: claude-opus-4-7)

# --- ツール制御（tools と disallowedTools は排他。どちらか一方のみ指定） ---
tools:                                # 許可するツールのリスト（省略時は全ツール継承）
  - Read
  - Write
  - Edit
  - Glob
  - Grep
  - Bash
# disallowedTools:                    # 拒否するツールのリスト（tools と同時指定不可）
#   - Write
#   - Edit

# --- 動作制御 ---
# permissionMode: default             # default | acceptEdits | auto | dontAsk | bypassPermissions | plan
# effort: high                        # low | medium | high | xhigh | max (xhigh は Claude Opus 4.7 で導入)
# maxTurns: 20                        # エージェントの最大ターン数（正の整数）
# background: false                   # true にするとバックグラウンドタスクとして実行
# isolation: worktree                 # "worktree" を指定すると一時的な git worktree で実行

# --- スキル・MCP ---
# skills:                             # 起動時にプリロードするスキル名のリスト
#   - skill-name
# mcpServers:                         # MCP サーバー参照またはインライン定義
#   - server-name
#   - name: inline-server
#     config: {}

# --- メモリ ---
# memory: project                     # user | project | local（永続メモリのスコープ）

# --- フック ---
# hooks:                              # ライフサイクルフック（PreToolUse, PostToolUse, Stop 等）
#   PreToolUse:
#     - command: "echo hook fired"

# --- 表示 ---
# color: blue                         # red | blue | green | yellow | purple | orange | pink | cyan

# --- 初期プロンプト ---
# initialPrompt: >                    # --agent / agent設定で起動時に自動送信される最初のユーザーターン
#   初期プロンプトをここに記述
---

# <Agent Name> — エージェント名を記述

## 役割

このエージェントの専門領域と責務を記述する。

## 実行プロセス

1. 最初のステップ
2. 次のステップ
3. ...

## 出力形式

エージェントの出力フォーマットを定義する。

## 制約事項

- このエージェントがやってはいけないことを記述する
