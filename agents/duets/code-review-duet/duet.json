{
  "name": "code-review-duet",
  "version": "1.0.0",
  "description": "コードレビューを実行し、レビュー結果の品質を QA エージェントが検査するデュエット。Actor-Critic パターンにより同意バイアスを排除した高品質なコードレビューを提供する。",
  "artifact_format": "text",
  "tags": ["code-review", "security", "quality"],
  "metadata": {
    "author": "duet-factory",
    "created_at": "2026-05-01T07:00:00Z"
  },
  "task_agent": {
    "name": "code-reviewer",
    "ref": "agents/agents/code-reviewer"
  },
  "qa_agent": {
    "name": "code-review-qa",
    "ref": "agents/agents/code-review-qa"
  },
  "workflow": {
    "execution": {
      "strategy": "direct"
    },
    "qa": {
      "max_iterations": 3,
      "pass_threshold": 0.80,
      "convergence_delta": 0.02,
      "keep_best": true
    }
  }
}
