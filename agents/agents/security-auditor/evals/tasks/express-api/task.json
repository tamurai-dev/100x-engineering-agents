      "type": "rubric",
      "grader_model": "claude-haiku-4-5"
    },
    "format": {
      "patterns": ["CRITICAL|HIGH|MEDIUM|LOW"],
      "required_sections": []
    }
  },
  "pass_threshold": {
    "outcome_score": 0.4
  }
}
