{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tamurai-dev/100x-engineering-agents/agents/schemas/managed-agent-config.schema.json",
  "title": "Claude Managed Agents Configuration",
  "description": "Anthropic Managed Agents API (managed-agents-2026-04-01) の agents.create パラメータに準拠した設定スキーマ",
  "type": "object",
  "required": ["name", "model", "system"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256,
      "description": "エージェント名。1-256文字"
    },
    "description": {
      "type": "string",
      "maxLength": 2048,
      "description": "エージェントの説明。最大2048文字"
    },
    "model": {
      "oneOf": [
        {
          "type": "string",
          "enum": [
            "claude-opus-4-6",
            "claude-sonnet-4-6",
            "claude-haiku-4-5",
            "claude-haiku-4-5-20251001",
            "claude-opus-4-5",
            "claude-opus-4-5-20251101",
            "claude-sonnet-4-5",
            "claude-sonnet-4-5-20250929"
          ]
        },
        {
          "type": "object",
          "required": ["id"],
          "additionalProperties": false,
          "properties": {
            "id": {
              "type": "string",
              "enum": [
                "claude-opus-4-6",
                "claude-sonnet-4-6",
                "claude-haiku-4-5",
                "claude-haiku-4-5-20251001",
                "claude-opus-4-5",
                "claude-opus-4-5-20251101",
                "claude-sonnet-4-5",
                "claude-sonnet-4-5-20250929"
              ]
            },
            "speed": {
              "type": "string",
              "enum": ["standard", "fast"],
              "description": "推論速度。fast はプレミアム料金。モデルによっては非対応"
            }
          }
        }
      ],
      "description": "使用モデル。文字列または model_config オブジェクト"
    },
    "system": {
      "type": "string",
      "maxLength": 100000,
      "description": "システムプロンプト。最大100,000文字"
    },
    "tools": {
      "type": "array",
      "maxItems": 128,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type"],
            "properties": {
              "type": {
                "type": "string",
                "const": "agent_toolset_20260401"
              },
              "default_config": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": {
                    "type": "boolean",
                    "description": "デフォルトでツールを有効にするか。未指定時は true"
                  },
                  "permission_policy": {
                    "$ref": "#/$defs/permission_policy"
                  }
                }
              },
              "configs": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["name"],
                  "additionalProperties": false,
                  "properties": {
                    "name": {
                      "type": "string",
                      "enum": ["bash", "edit", "read", "write", "glob", "grep", "web_fetch", "web_search"],
                      "description": "ビルトインツール名"
                    },
                    "enabled": {
                      "type": "boolean"
                    },
                    "permission_policy": {
                      "$ref": "#/$defs/permission_policy"
                    }
                  }
                }
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "mcp_server_name"],
            "properties": {
              "type": {
                "type": "string",
                "const": "mcp_toolset"
              },
              "mcp_server_name": {
                "type": "string",
                "minLength": 1,
                "maxLength": 255,
                "description": "MCP サーバー名。mcp_servers 配列内の name と一致する必要がある"
              },
              "default_config": {
                "type": "object",
                "additionalProperties": false,
                "properties": {
                  "enabled": { "type": "boolean" },
                  "permission_policy": {
                    "$ref": "#/$defs/permission_policy"
                  }
                }
              }
            },
            "additionalProperties": false
          },
          {
            "type": "object",
            "required": ["type", "name", "input_schema"],
            "properties": {
              "type": {
                "type": "string",
                "const": "custom"
              },
              "name": {
                "type": "string",
                "description": "カスタムツール名"
              },
              "description": {
                "type": "string",
                "description": "ツールの説明"
              },
              "input_schema": {
                "type": "object",
                "description": "JSON Schema 形式の入力スキーマ"
              }
            },
            "additionalProperties": false
          }
        ]
      },
      "description": "ツール設定。全ツールセット合計で最大128"
    },
    "mcp_servers": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "type": "object",
        "required": ["type", "name", "url"],
        "additionalProperties": false,
        "properties": {
          "type": {
            "type": "string",
            "const": "url"
          },
          "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255,
            "description": "サーバー名（ユニーク）"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "MCP サーバーの URL"
          }
        }
      },
      "description": "MCP サーバー。最大20"
    },
    "skills": {
      "type": "array",
      "maxItems": 20,
      "items": {
        "oneOf": [
          {
            "type": "object",
            "required": ["type", "skill_id"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "const": "anthropic"
              },
              "skill_id": {
                "type": "string",
                "description": "Anthropic スキル ID"
              },
              "version": {
                "type": "string",
                "description": "バージョン固定。省略時は latest"
              }
            }
          },
          {
            "type": "object",
            "required": ["type", "skill_id"],
            "additionalProperties": false,
            "properties": {
              "type": {
                "type": "string",
                "const": "custom"
              },
              "skill_id": {
                "type": "string",
                "description": "カスタムスキル ID"
              },
              "version": {
                "type": "string"
              }
            }
          }
        ]
      },
      "description": "スキル設定。最大20"
    },
    "metadata": {
      "type": "object",
      "maxProperties": 16,
      "patternProperties": {
        "^.{1,64}$": {
          "type": "string",
          "maxLength": 512
        }
      },
      "additionalProperties": false,
      "description": "任意メタデータ。最大16ペア、キー64文字、値512文字"
    }
  },
  "$defs": {
    "permission_policy": {
      "oneOf": [
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "const": "always_allow"
            }
          }
        },
        {
          "type": "object",
          "required": ["type"],
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "const": "always_ask"
            }
          }
        }
      ],
      "description": "ツール実行の権限ポリシー"
    }
  }
}
