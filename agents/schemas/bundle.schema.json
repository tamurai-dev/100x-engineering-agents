{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tamurai-dev/100x-engineering-agents/agents/schemas/bundle.schema.json",
  "title": "Agent Bundle Configuration",
  "description": "Task Agent + QA Agent のペアで構成されるバンドル定義スキーマ。バンドルは2体のエージェントを結合し、タスク実行→QA→修正のワークフローを定義する。",
  "type": "object",
  "required": ["name", "version", "description", "artifact_format", "task_agent", "qa_agent", "workflow"],
  "additionalProperties": false,
  "$defs": {
    "agent_ref": {
      "type": "object",
      "required": ["name", "ref"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "minLength": 1,
          "description": "エージェント名（agents/agents/ 配下のディレクトリ名）"
        },
        "ref": {
          "type": "string",
          "pattern": "^agents/agents/[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "エージェントのディレクトリパス"
        }
      }
    },
    "skill_entry": {
      "type": "object",
      "required": ["type", "skill_id"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "type": "string",
          "enum": ["anthropic", "custom"],
          "description": "スキルのソース。anthropic: プリビルト、custom: カスタムアップロード"
        },
        "skill_id": {
          "type": "string",
          "minLength": 1,
          "description": "スキル ID。anthropic: pptx/xlsx/docx/pdf、custom: skill_xxx"
        },
        "version": {
          "type": "string",
          "default": "latest",
          "description": "スキルバージョン。latest またはバージョン文字列"
        }
      },
      "description": "Managed Agents API のスキル定義"
    },
    "package_list": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "apt": {
          "type": "array",
          "items": { "type": "string" },
          "description": "apt-get でインストールするシステムパッケージ"
        },
        "cargo": {
          "type": "array",
          "items": { "type": "string" },
          "description": "cargo でインストールする Rust パッケージ"
        },
        "gem": {
          "type": "array",
          "items": { "type": "string" },
          "description": "gem でインストールする Ruby パッケージ"
        },
        "go": {
          "type": "array",
          "items": { "type": "string" },
          "description": "go install でインストールする Go パッケージ"
        },
        "npm": {
          "type": "array",
          "items": { "type": "string" },
          "description": "npm でインストールする Node.js パッケージ"
        },
        "pip": {
          "type": "array",
          "items": { "type": "string" },
          "description": "pip でインストールする Python パッケージ"
        }
      },
      "description": "Environment にプリインストールするパッケージ（マネージャ別）"
    }
  },
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]-bundle$",
      "minLength": 3,
      "maxLength": 128,
      "description": "バンドル名。小文字+ハイフンのみ。末尾は -bundle"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "セマンティックバージョニング"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2048,
      "description": "バンドルの説明"
    },
    "artifact_format": {
      "type": "string",
      "enum": [
        "text",
        "code",
        "structured_data",
        "document",
        "presentation",
        "html_ui",
        "media_image",
        "media_video",
        "environment_state"
      ],
      "description": "成果物のフォーマット。QA 戦略の自動選択に使用"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string",
        "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]$"
      },
      "uniqueItems": true,
      "maxItems": 20,
      "description": "バンドルの分類タグ（検索・フィルタ用）"
    },
    "metadata": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "author": {
          "type": "string",
          "description": "バンドル作成者"
        },
        "created_at": {
          "type": "string",
          "format": "date-time",
          "description": "作成日時（ISO 8601）"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time",
          "description": "更新日時（ISO 8601）"
        }
      },
      "description": "バンドルのメタデータ"
    },
    "task_agent": {
      "$ref": "#/$defs/agent_ref",
      "description": "タスク実行を担当するエージェント（Actor）"
    },
    "qa_agent": {
      "$ref": "#/$defs/agent_ref",
      "description": "品質検査を担当するエージェント（Critic、fresh-context で起動）"
    },
    "skill": {
      "type": "string",
      "description": "SKILL.md のパス（バンドルディレクトリからの相対パス）"
    },
    "skills": {
      "type": "array",
      "items": { "$ref": "#/$defs/skill_entry" },
      "maxItems": 20,
      "description": "Managed Agents API に渡すスキル一覧。プリビルト（pptx/xlsx/docx/pdf）またはカスタムスキル。最大20個/セッション"
    },
    "environment": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "packages": {
          "$ref": "#/$defs/package_list",
          "description": "Agent 起動前にインストールするパッケージ"
        },
        "networking": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": {
              "type": "string",
              "enum": ["unrestricted", "restricted"],
              "default": "unrestricted",
              "description": "ネットワークアクセス設定"
            }
          },
          "description": "ネットワーク設定"
        }
      },
      "description": "Managed Agents API の Environment 設定。パッケージのプリインストールとネットワーク設定"
    },
    "workflow": {
      "type": "object",
      "required": ["qa"],
      "additionalProperties": false,
      "properties": {
        "pre_task": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read_skills": {
              "type": "boolean",
              "default": true,
              "description": "SKILL.md を Task Agent のコンテキストに注入するか"
            },
            "verify_packages": {
              "type": "array",
              "items": { "type": "string" },
              "description": "事前にインストール確認するパッケージ名"
            }
          },
          "description": "タスク実行前の準備設定"
        },
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["script_generation", "direct", "hybrid"],
              "default": "direct",
              "description": "タスク実行戦略。script_generation: スクリプト生成→実行、direct: 直接実行、hybrid: 混合"
            }
          },
          "description": "タスク実行設定"
        },
        "qa": {
          "type": "object",
          "required": ["max_iterations", "pass_threshold"],
          "additionalProperties": false,
          "properties": {
            "max_iterations": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 3,
              "description": "QA ループの最大反復回数"
            },
            "pass_threshold": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "default": 0.80,
              "description": "QA 合格スコア閾値（0.0〜1.0）"
            },
            "convergence_delta": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 0.5,
              "default": 0.02,
              "description": "収束判定の閾値。前回との差が delta 以下なら収束とみなす"
            },
            "keep_best": {
              "type": "boolean",
              "default": true,
              "description": "全ラウンドの成果物を保存し、最高スコア版を最終成果物とする"
            },
            "escalation_threshold": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "default": 0.40,
              "description": "モデルエスカレーション閾値。QAスコアがこの値以下かつ改善なしの場合、上位モデルに自動切替"
            },
            "model_escalation": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["haiku", "sonnet", "opus"]
              },
              "minItems": 1,
              "maxItems": 3,
              "uniqueItems": true,
              "default": ["haiku", "sonnet"],
              "description": "モデルエスカレーション順序。スコアが escalation_threshold 以下の場合に次のモデルへ自動切替"
            }
          },
          "description": "QA ループ設定"
        }
      },
      "description": "ワークフロー実行設定"
    }
  }
}
