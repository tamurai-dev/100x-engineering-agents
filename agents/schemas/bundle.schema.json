{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tamurai-dev/100x-engineering-agents/agents/schemas/bundle.schema.json",
  "title": "Agent Bundle Configuration",
  "description": "Task Agent + QA Agent のペアで構成されるバンドル定義スキーマ。バンドルは2体のエージェントを結合し、タスク実行→QA→修正のワークフローを定義する。",
  "type": "object",
  "required": ["name", "version", "description", "artifact_format", "task_agent", "qa_agent", "workflow"],
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*[a-z0-9]-bundle$",
      "minLength": 3,
      "maxLength": 128,
      "description": "バンドル名。小文字+ハイフンのみ。末尾は -bundle"
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$",
      "description": "セマンティックバージョニング"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 2048,
      "description": "バンドルの説明"
    },
    "artifact_format": {
      "type": "string",
      "enum": [
        "text",
        "code",
        "structured_data",
        "document",
        "presentation",
        "html_ui",
        "media_image",
        "media_video",
        "environment_state"
      ],
      "description": "成果物のフォーマット。QA 戦略の自動選択に使用"
    },
    "task_agent": {
      "type": "object",
      "required": ["name", "ref"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "Task Agent のエージェント名（agents/agents/ 配下のディレクトリ名）"
        },
        "ref": {
          "type": "string",
          "pattern": "^agents/agents/[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "Task Agent のディレクトリパス"
        }
      },
      "description": "タスク実行を担当するエージェント"
    },
    "qa_agent": {
      "type": "object",
      "required": ["name", "ref"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1,
          "description": "QA Agent のエージェント名（agents/agents/ 配下のディレクトリ名）"
        },
        "ref": {
          "type": "string",
          "pattern": "^agents/agents/[a-z0-9][a-z0-9-]*[a-z0-9]$",
          "description": "QA Agent のディレクトリパス"
        }
      },
      "description": "品質検査を担当するエージェント（fresh-context で起動）"
    },
    "skill": {
      "type": "string",
      "description": "SKILL.md のパス（バンドルディレクトリからの相対パス）"
    },
    "workflow": {
      "type": "object",
      "required": ["qa"],
      "additionalProperties": false,
      "properties": {
        "pre_task": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "read_skills": {
              "type": "boolean",
              "default": true,
              "description": "SKILL.md を Task Agent のコンテキストに注入するか"
            },
            "verify_packages": {
              "type": "array",
              "items": { "type": "string" },
              "description": "事前にインストール確認するパッケージ名"
            }
          },
          "description": "タスク実行前の準備設定"
        },
        "execution": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "strategy": {
              "type": "string",
              "enum": ["script_generation", "direct", "hybrid"],
              "default": "direct",
              "description": "タスク実行戦略。script_generation: スクリプト生成→実行、direct: 直接実行、hybrid: 混合"
            }
          },
          "description": "タスク実行設定"
        },
        "qa": {
          "type": "object",
          "required": ["max_iterations", "pass_threshold"],
          "additionalProperties": false,
          "properties": {
            "max_iterations": {
              "type": "integer",
              "minimum": 1,
              "maximum": 10,
              "default": 3,
              "description": "QA ループの最大反復回数"
            },
            "pass_threshold": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 1.0,
              "default": 0.80,
              "description": "QA 合格スコア閾値（0.0〜1.0）"
            },
            "convergence_delta": {
              "type": "number",
              "minimum": 0.0,
              "maximum": 0.5,
              "default": 0.02,
              "description": "収束判定の閾値。前回との差が delta 以下なら収束とみなす"
            },
            "keep_best": {
              "type": "boolean",
              "default": true,
              "description": "全ラウンドの成果物を保存し、最高スコア版を最終成果物とする"
            }
          },
          "description": "QA ループ設定"
        }
      },
      "description": "ワークフロー実行設定"
    }
  }
}
