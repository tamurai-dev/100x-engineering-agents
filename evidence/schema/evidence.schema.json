{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/tamurai-dev/100x-engineering-agents/evidence/schema/evidence.schema.json",
  "title": "Execution Evidence",
  "description": "成果物の動作検証証跡スキーマ",
  "type": "object",
  "required": ["subject", "type", "date", "verifications", "hmac_sha256"],
  "additionalProperties": false,
  "properties": {
    "subject": {
      "type": "string",
      "description": "検証対象のファイルパス（リポジトリルート相対）",
      "pattern": "^[a-zA-Z0-9_./-]+$"
    },
    "type": {
      "type": "string",
      "enum": ["new-script", "modified-script", "new-agent", "modified-agent", "integration", "other"],
      "description": "証跡の種別"
    },
    "date": {
      "type": "string",
      "format": "date-time",
      "description": "検証実行日時（ISO 8601）"
    },
    "commit": {
      "type": "string",
      "description": "検証時点のコミットSHA（あれば）"
    },
    "verifications": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/verification"
      },
      "description": "検証項目のリスト"
    },
    "hmac_sha256": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$",
      "description": "エントリ全体のHMAC-SHA256署名"
    }
  },
  "$defs": {
    "verification": {
      "type": "object",
      "required": ["name", "result"],
      "additionalProperties": false,
      "properties": {
        "name": {
          "type": "string",
          "minLength": 5,
          "description": "検証項目名"
        },
        "command": {
          "type": "string",
          "description": "実行したコマンド（run モードで自動記録）"
        },
        "exit_code": {
          "type": "integer",
          "description": "コマンドの終了コード（run モードで自動記録）"
        },
        "stdout_snippet": {
          "type": "string",
          "maxLength": 2000,
          "description": "標準出力の抜粋（最大2000文字）"
        },
        "stderr_snippet": {
          "type": "string",
          "maxLength": 1000,
          "description": "標準エラー出力の抜粋（最大1000文字）"
        },
        "note": {
          "type": "string",
          "maxLength": 500,
          "description": "補足説明（log モードで使用）"
        },
        "result": {
          "type": "string",
          "enum": ["pass", "fail", "skip"],
          "description": "検証結果"
        }
      }
    }
  }
}
