{
  "name": "bad-ref-duet",
  "version": "1.0.0",
  "description": "ref パスの形式が不正なデュエット。agents/agents/ プレフィックスが必要。",
  "artifact_format": "text",
  "task_agent": {
    "name": "code-reviewer",
    "ref": "some/invalid/path"
  },
  "qa_agent": {
    "name": "code-review-qa",
    "ref": "agents/agents/code-review-qa"
  },
  "workflow": {
    "qa": {
      "max_iterations": 3,
      "pass_threshold": 0.80
    }
  }
}
