{
  "name": "code-review-bundle",
  "version": "1.2.3",
  "description": "全フィールドを含むバリデーション用バンドル定義。tags と metadata を含む。",
  "artifact_format": "code",
  "tags": ["code-review", "security", "quality"],
  "metadata": {
    "author": "bundle-factory",
    "created_at": "2026-05-01T07:00:00Z",
    "updated_at": "2026-05-01T08:00:00Z"
  },
  "task_agent": {
    "name": "code-reviewer",
    "ref": "agents/agents/code-reviewer"
  },
  "qa_agent": {
    "name": "code-review-qa",
    "ref": "agents/agents/code-review-qa"
  },
  "skill": "agents/bundles/code-review-bundle/skill.md",
  "workflow": {
    "pre_task": {
      "read_skills": true,
      "verify_packages": ["pylint"]
    },
    "execution": {
      "strategy": "script_generation"
    },
    "qa": {
      "max_iterations": 5,
      "pass_threshold": 0.85,
      "convergence_delta": 0.01,
      "keep_best": true,
      "escalation_threshold": 0.40,
      "model_escalation": ["haiku", "sonnet"]
    }
  }
}
